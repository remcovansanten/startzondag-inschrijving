# Database Configuration
# For development: Use local PostgreSQL or Prisma Accelerate
# For production: Use PostgreSQL with Prisma Accelerate
DATABASE_URL="postgresql://user:password@localhost:5432/startzondag_dev"

# Admin Credentials
# Change these in production!
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-secure-password"

# Security
# Generate with: openssl rand -base64 32
JWT_SECRET="your-secret-key-min-32-chars-change-this-in-production"

# Email Service (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="Startzondag GKE <noreply@your-domain.nl>"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Environment
NODE_ENV="development"