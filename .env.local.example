# Database
# SQLite database file location
DATABASE_URL="file:./dev.db"

# Admin Credentials
# Change these in production!
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# Security
# Generate a secure random string of at least 32 characters
# You can use: openssl rand -base64 32
JWT_SECRET="your-secret-key-min-32-chars-change-this-in-production"

# Email Service (Optional)
# The app works without email configuration, but emails won't be sent

# Option 1: Resend (Recommended)
# Sign up at https://resend.com and get your API key
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="noreply@yourdomain.nl"

# Option 2: Gmail SMTP (Alternative)
# Enable 2FA on your Google account and create an app password
# Uncomment and fill these if using Gmail instead of Resend
# GMAIL_USER="your-email@gmail.com"
# GMAIL_APP_PASSWORD="your-16-char-app-password"

# Site Configuration
# The public URL of your site (used in emails)
# In production, change this to your actual domain
NEXT_PUBLIC_SITE_URL="http://localhost:3000"